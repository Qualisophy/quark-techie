---
import '../styles/global.css';
import { Navbar } from '../components/react/layout/Navbar';
import { Footer } from '../components/react/layout/Footer';
import { ToastContainer } from '../components/react/shared/ui/Toast';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Quark Techie - Código Evolucionado" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <script id="cookieyes" type="text/javascript" src="https://cdn-cookieyes.com/client_data/7f255d4a56a7b4004412e47cba6919e4/script.js"></script> 
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&display=swap" rel="stylesheet">
    <link 
      rel="icon" 
      type="image/svg+xml" 
      href="/favicon_light.svg" 
      media="(prefers-color-scheme: light)" 
    />
    <link 
      rel="icon" 
      type="image/svg+xml" 
      href="/favicon_dark.svg" 
      media="(prefers-color-scheme: dark)" 
    />
    <title>{title}</title>
  </head>
  <body class="bg-[#050505] text-[#F5F5F7] min-h-screen font-sans selection:bg-[#288B88]/40 selection:text-white overflow-x-hidden relative flex flex-col">
    
    <div class="fixed top-[-20%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-[#288B88]/10 blur-[150px] mix-blend-screen pointer-events-none z-0"></div>
    <div class="fixed bottom-[-20%] right-[-10%] w-[40vw] h-[40vw] rounded-full bg-[#E8D33F]/10 blur-[150px] mix-blend-screen pointer-events-none z-0"></div>
    
    <div class="fixed inset-0 opacity-[0.015] pointer-events-none z-0" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 200 200\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noiseFilter\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.85\' numOctaves=\'3\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noiseFilter)\'/%3E%3C/svg%3E');"></div>

    <Navbar currentPath={currentPath} client:load />

    <main class="relative z-10 w-full grow">
      <slot />
    </main>

    <Footer client:load />

    <ToastContainer client:load />

    <script>
      function setupCookieButtonLogic() {
        const footer = document.querySelector('footer');
        if (!footer) return;

        const observer = new MutationObserver((mutations, obs) => {
          const cookieBtn = document.querySelector('.cky-revisit-bottom-left, .cky-revisit-bottom-right, .cky-btn-revisit') as HTMLElement;
          
          if (cookieBtn) {
            obs.disconnect(); 
            
            cookieBtn.style.transition = 'transform 0.3s ease-out, opacity 0.3s ease-out';

            const adjustPosition = () => {
              const footerRect = footer.getBoundingClientRect();
              const windowHeight = window.innerHeight;
              const isMobile = window.innerWidth < 768; 

              const overlap = windowHeight - footerRect.top;

              if (overlap > 0) {
                if (isMobile) {
                  cookieBtn.style.opacity = '0';
                  cookieBtn.style.pointerEvents = 'none';
                } else {
                  cookieBtn.style.transform = `translateY(-${overlap}px)`;
                  cookieBtn.style.opacity = '1';
                  cookieBtn.style.pointerEvents = 'auto';
                }
              } else {
                cookieBtn.style.transform = 'translateY(0)';
                cookieBtn.style.opacity = '1';
                cookieBtn.style.pointerEvents = 'auto';
              }
            };

            window.addEventListener('scroll', adjustPosition, { passive: true });
            window.addEventListener('resize', adjustPosition, { passive: true });
            
            adjustPosition();
          }
        });

        observer.observe(document.body, { childList: true, subtree: true });
      }

      document.addEventListener('DOMContentLoaded', setupCookieButtonLogic);
      document.addEventListener('astro:page-load', setupCookieButtonLogic);
    </script>
  </body>
</html>