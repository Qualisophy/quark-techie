---
import Layout from "../../layouts/Layout.astro";
import { Reveal } from "../../components/react/shared/Reveal";
import { ArrowLeft } from "lucide-react";
// IMPORTAMOS LA TABLA DESDE EL ARCHIVO MADRE
import { TalentTable } from "../../components/react/talenthub/TalentHub"; 
---

<Layout title="Base de Talento Certificado | Quark Techie">
  <main class="pt-32 pb-20 px-6 max-w-7xl mx-auto min-h-screen relative overflow-hidden">
    
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-[#288B88]/5 blur-[120px] rounded-full -z-10"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-[#D9C58F]/5 blur-[150px] rounded-full -z-10"></div>

    <section class="mb-16">
      <Reveal client:load>
        <a href="/talent-hub" class="flex items-center gap-2 text-gray-500 hover:text-white transition-colors mb-8 group w-fit">
          <ArrowLeft size={16} className="group-hover:-translate-x-1 transition-transform" />
          Volver al Hub
        </a>
        
        <h1 class="text-4xl md:text-6xl font-semibold text-white tracking-tighter mb-8 leading-tight text-center">
          Nuestra Base de <br />
          Talento Certificado
        </h1>
        
        <p class="text-gray-400 text-lg md:text-xl font-light max-w-3xl leading-relaxed text-center mx-auto">
          Explora los perfiles de nuestros graduados. Todos han superado un riguroso proceso de validación técnica y están listos para integrarse en equipos de alto rendimiento.
        </p>
      </Reveal>
    </section>

    <section>
      <Reveal client:load delay={200}>
        <div class="w-full bg-white/[0.02] border border-white/10 rounded-[2.5rem] overflow-hidden backdrop-blur-3xl shadow-2xl relative">
          <TalentTable client:load /> 
        </div>
      </Reveal>
    </section>

  </main>
</Layout>