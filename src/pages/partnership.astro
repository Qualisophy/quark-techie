---
import Layout from '../layouts/Layout.astro';
import { Partnership as PartnershipComponent } from '../components/react/partnership/Partnership';
import { CTA } from "../components/react/shared/ui/CTA";
---

<Layout title="Partnership para Agencias | Quark Techie">
  <PartnershipComponent client:load />
  
  <section class="pb-32 pt-12 px-6 max-w-6xl mx-auto">
     <CTA client:visible buttonText="Proponer Colaboración" href="/contacto" className="w-full text-center">
        <h2 class="text-4xl md:text-5xl font-semibold text-white mb-6 tracking-tight">
          ¿Hablamos de tu próximo gran proyecto?
        </h2>
        <p class="text-gray-400 font-light max-w-2xl mx-auto text-lg leading-relaxed">
          Únete a las agencias que ya están escalando sus operaciones delegando la complejidad técnica en nuestro equipo.
        </p>
     </CTA>
  </section>
</Layout>